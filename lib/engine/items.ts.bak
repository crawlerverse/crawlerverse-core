/**
 * Item Types and Schemas
 *
 * Defines the core data structures for the item system.
 * Items are divided into two categories:
 * - Consumables: Single-use items with instant effects (potions, scrolls)
 * - Equipment: Wearable items providing persistent stat bonuses (weapons, armor)
 *
 * The item system uses discriminated unions for type-safe polymorphism,
 * matching the patterns used in ActionSchema and TileSchema.
 */

import { z } from 'zod';
import type { DungeonMap, Room } from './map';
import { isPassable } from './map';

// --- Modifier System ---

/**
 * A stat modifier that changes an entity's stats.
 * Used by both consumables (instant healing) and equipment (stat bonuses).
 */
export const ModifierSchema = z.object({
  stat: z.enum(['hp', 'maxHp', 'attack', 'defense', 'speed']),
  delta: z.number().int(),
});
export type Modifier = z.infer<typeof ModifierSchema>;

/**
 * An effect bundles one or more modifiers with a duration.
 * - 'instant': Applied once immediately (consumables)
 * - 'while_equipped': Active only while item is equipped
 */
export const EffectSchema = z.object({
  modifiers: z.array(ModifierSchema),
  duration: z.enum(['instant', 'while_equipped']),
});
export type Effect = z.infer<typeof EffectSchema>;

// --- Item Appearance ---

/**
 * Visual representation of an item on the map.
 * char: Single ASCII character (roguelike tradition)
 * color: Hex color string for rendering (#RRGGBB format)
 */
export const ItemAppearanceSchema = z.object({
  char: z.string().length(1),
  color: z.string().regex(/^#[0-9A-Fa-f]{6}$/, 'Color must be hex format #RRGGBB'),
});
export type ItemAppearance = z.infer<typeof ItemAppearanceSchema>;

// --- Item Templates (Discriminated Union) ---

/**
 * Base consumable template schema without refinement.
 * Used in discriminated union (refinement at union level).
 */
const ConsumableTemplateBaseSchema = z.object({
  type: z.literal('consumable'),
  id: z.string().min(1),
  name: z.string().min(1),
  tier: z.number().int().positive(),
  appearance: ItemAppearanceSchema,
  effect: EffectSchema,
  lore: z.string().optional(),
});

/**
 * Consumable item template.
 * Single-use items that are destroyed on use.
 * Examples: health potions, mana potions, scrolls
 */
export const ConsumableTemplateSchema = ConsumableTemplateBaseSchema.refine(
  (t) => t.effect.duration === 'instant',
  { message: 'Consumables must have instant effects' }
);
export type ConsumableTemplate = z.infer<typeof ConsumableTemplateSchema>;

/**
 * Base equipment template schema without refinement.
 * Used in discriminated union (refinement at union level).
 */
const EquipmentTemplateBaseSchema = z.object({
  type: z.literal('equipment'),
  id: z.string().min(1),
  name: z.string().min(1),
  tier: z.number().int().positive(),
  slot: z.enum(['weapon', 'armor', 'offhand']),
  appearance: ItemAppearanceSchema,
  effect: EffectSchema,
  // Ranged weapon properties (optional)
  range: z.number().int().positive().optional(),
  rangedType: z.enum(['bow', 'thrown']).optional(),
  // Quiver properties (optional)
  capacity: z.number().int().positive().optional(),
  currentAmmo: z.number().int().nonnegative().optional(),
  // Stackable items (thrown weapons)
  stackable: z.boolean().optional(),
  quantity: z.number().int().positive().optional(),
