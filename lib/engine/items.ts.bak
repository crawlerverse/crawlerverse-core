/**
 * Immutable item template registry.
 * Frozen to prevent accidental mutation of template definitions.
 */
export const ITEM_TEMPLATES: Readonly<Record<string, ItemTemplate>> = Object.freeze(_ITEM_TEMPLATES);

/**
 * Valid item template IDs.
 * Derived from ITEM_TEMPLATES keys for type safety.
 */
export type ItemTemplateId = keyof typeof _ITEM_TEMPLATES;

/** Get item template by ID */
export function getItemTemplate(templateId: string): ItemTemplate | undefined {
  return ITEM_TEMPLATES[templateId];
}

// --- Spawning Configuration ---

/**
 * Configuration for item spawning on a floor.
 * minItems must be <= maxItems, both must be non-negative.
 * floor must be positive (1-indexed).
 */
export const ItemSpawnConfigSchema = z.object({
  minItems: z.number().int().nonnegative(),
  maxItems: z.number().int().nonnegative(),
  floor: z.number().int().positive(),
}).refine(
  (c) => c.minItems <= c.maxItems,
  { message: 'minItems must be <= maxItems' }
);
export type ItemSpawnConfig = z.infer<typeof ItemSpawnConfigSchema>;

export const DEFAULT_ITEM_SPAWN_CONFIG: ItemSpawnConfig = {
  minItems: 2,
  maxItems: 4,
  floor: 1,
};

// --- Spawning Helpers ---

/** Get templates by tier */
function getTemplatesByTier(tier: number): ItemTemplate[] {
  return Object.values(ITEM_TEMPLATES).filter(t => t.tier === tier);
}

/** Calculate tier weights based on floor depth */
function getTierWeights(floor: number): Map<number, number> {
  // Floor 1: 90% tier 1, 10% tier 2
  // Floor 3: 70% tier 1, 30% tier 2
  // Floor 5: 50% tier 1, 50% tier 2
  const tier2Weight = Math.min(0.5, 0.1 + (floor - 1) * 0.1);
  return new Map([
    [1, 1 - tier2Weight],
    [2, tier2Weight],
  ]);
}

/**
 * Select a random template from a tier.
 * Throws with descriptive error if tier is empty.
 */
function selectFromTier(
  tier: number,
  rng: { getUniform: () => number },
  errorContext: string
): ItemTemplate {
  const templates = getTemplatesByTier(tier);
  if (templates.length === 0) {
    throw new Error(
      `No item templates found for tier ${tier}. ${errorContext}`
    );
  }
  const index = Math.floor(rng.getUniform() * templates.length);
  return templates[index];
}

/**
 * Select a random template based on floor-weighted tiers.
 * Throws if no templates exist for the selected tier.
 */
function selectRandomTemplate(
  floor: number,
  rng: { getUniform: () => number }
): ItemTemplate {
  const weights = getTierWeights(floor);
  const roll = rng.getUniform();

  let cumulative = 0;
  for (const [tier, weight] of weights) {
    cumulative += weight;
    if (roll < cumulative) {
      return selectFromTier(
        tier,
        rng,
        'This indicates a configuration error in ITEM_TEMPLATES.'
      );
    }
  }

  // Fallback to tier 1
  return selectFromTier(
    1,
    rng,
    'The item system requires at least one tier 1 template to function.'
  );
}

/** Get valid spawn rooms (exclude starting room) */
function getSpawnRooms(map: DungeonMap): readonly Room[] {
  return map.rooms.filter(room => !room.tags.includes('starting'));
}

/**
 * Get random floor position within a room interior.
 * Uses 1-tile margin from room edges to avoid spawning near walls.
 */
function getRandomRoomPosition(
  map: DungeonMap,
  room: Room,
  exclude: Set<string>,
  rng: { getUniform: () => number }
): { x: number; y: number } | null {
  const candidates: { x: number; y: number }[] = [];

  // Use 1-tile margin from room edges to avoid visual overlap with walls
  const innerLeft = room.x + 1;
  const innerTop = room.y + 1;
  const innerRight = room.x + room.width - 2;
  const innerBottom = room.y + room.height - 2;

  for (let y = innerTop; y <= innerBottom; y++) {
    for (let x = innerLeft; x <= innerRight; x++) {
      const key = `${x},${y}`;
      if (isPassable(map, x, y) && !exclude.has(key)) {
        candidates.push({ x, y });
      }
    }
  }

  if (candidates.length === 0) return null;
  return candidates[Math.floor(rng.getUniform() * candidates.length)];
}

/**
 * Spawn items for a floor.
 * Returns spawned items. May return fewer than requested if spawn positions are exhausted.
 */
export function spawnItems(
  map: DungeonMap,
  config: ItemSpawnConfig,
  excludePositions: Array<{ x: number; y: number }>,
  rng: { getUniform: () => number },
  areaId: string
): ItemInstance[] {
  const { minItems, maxItems, floor } = config;
  const count = minItems + Math.floor(rng.getUniform() * (maxItems - minItems + 1));

  const rooms = getSpawnRooms(map);
  if (rooms.length === 0) {
    // No non-starting rooms available for item spawning
    return [];
  }

  const exclude = new Set(excludePositions.map(p => `${p.x},${p.y}`));
  const items: ItemInstance[] = [];

  for (let i = 0; i < count; i++) {
    // Pick random room
    const room = rooms[Math.floor(rng.getUniform() * rooms.length)];
    const pos = getRandomRoomPosition(map, room, exclude, rng);

    if (pos) {
      const template = selectRandomTemplate(floor, rng);
      // Use globally unique ID: seed-floor-index
      items.push({
        id: `item-${map.seed}-${floor}-${i}`,
        templateId: template.id,
        x: pos.x,
        y: pos.y,
        areaId,
      });
      exclude.add(`${pos.x},${pos.y}`);
    }
    // Note: if pos is null, we silently skip this item.
    // This is intentional - we return fewer items than requested when
    // spawn positions are exhausted.
  }

  return items;
}
