>>>>>>> origin/main
});

/**
 * Equipment item template.
 * Items that can be equipped to provide ongoing bonuses.
 * Supports weapon, armor, and offhand slots.
 *
 * Property constraints enforced by refinement:
 * - range and rangedType must both be present or both absent
 * - rangedType requires slot === 'weapon'
 * - capacity/currentAmmo require slot === 'offhand' (quiver)
 * - stackable/quantity require rangedType === 'thrown'
 * - currentAmmo cannot exceed capacity
 */
export const EquipmentTemplateSchema = EquipmentTemplateBaseSchema
  .refine(
    (t) => t.effect.duration === 'while_equipped',
    { message: 'Equipment must have while_equipped effects' }
  )
  .refine(
    (t) => {
      // Ranged weapons: range requires rangedType and vice versa
      const hasRange = t.range !== undefined;
      const hasRangedType = t.rangedType !== undefined;
      return hasRange === hasRangedType;
    },
    { message: 'Ranged weapons must have both range and rangedType, or neither' }
  )
  .refine(
    (t) => {
      // rangedType requires weapon slot
      if (t.rangedType !== undefined && t.slot !== 'weapon') {
        return false;
      }
      return true;
    },
    { message: 'Ranged weapons must have slot: weapon' }
  )
  .refine(
    (t) => {
      // Quiver properties only valid on offhand
      if ((t.capacity !== undefined || t.currentAmmo !== undefined) && t.slot !== 'offhand') {
        return false;
      }
      return true;
    },
    { message: 'Quiver properties (capacity/currentAmmo) require slot: offhand' }
  )
  .refine(
    (t) => {
      // Stackable/quantity only valid on thrown weapons
      if ((t.stackable === true || t.quantity !== undefined) && t.rangedType !== 'thrown') {
        return false;
      }
      return true;
    },
    { message: 'Stackable/quantity only valid for thrown weapons' }
  )
  .refine(
    (t) => {
      // currentAmmo cannot exceed capacity on quivers
      if (t.capacity !== undefined && t.currentAmmo !== undefined) {
        return t.currentAmmo <= t.capacity;
      }
      return true;
    },
    { message: 'currentAmmo cannot exceed capacity' }
  );
export type EquipmentTemplate = z.infer<typeof EquipmentTemplateSchema>;

/**
 * Discriminated union of all item templates (base schemas for union).
 * Use the 'type' field to narrow to specific item types.
 */
const ItemTemplateBaseSchema = z.discriminatedUnion('type', [
  ConsumableTemplateBaseSchema,
  EquipmentTemplateBaseSchema,
]);

/**
 * Validated item template schema with duration constraints.
 * - Consumables must have 'instant' duration
 * - Equipment must have 'while_equipped' duration
 *
 * @example
 * const item = ItemTemplateSchema.parse(data);
 * if (item.type === 'consumable') {
 *   // TypeScript knows item is ConsumableTemplate
 *   console.log(item.effect.duration); // 'instant'
 * }
 */
export const ItemTemplateSchema = ItemTemplateBaseSchema.refine(
  (t) => {
    if (t.type === 'consumable') return t.effect.duration === 'instant';
    if (t.type === 'equipment') return t.effect.duration === 'while_equipped';
    return true;
  },
  (t) => ({
    message: t.type === 'consumable'
      ? 'Consumables must have instant effects'
      : 'Equipment must have while_equipped effects',
  })
);
export type ItemTemplate = z.infer<typeof ItemTemplateBaseSchema>;

// --- Type Guards ---

/**
 * Type guard to check if a template is equipment.
 * Enables TypeScript narrowing without type assertions.
 *
 * @example
 * ```typescript
 * const template = getItemTemplate(id);
 * if (template && isEquipmentTemplate(template)) {
 *   // TypeScript knows template is EquipmentTemplate
 *   console.log(template.slot); // 'weapon' | 'armor' | 'offhand'
 * }
 * ```
 */
export function isEquipmentTemplate(template: ItemTemplate): template is EquipmentTemplate {
  return template.type === 'equipment';
}

/**
 * Type guard to check if a template is a consumable.
 * Enables TypeScript narrowing without type assertions.
 */
export function isConsumableTemplate(template: ItemTemplate): template is ConsumableTemplate {
  return template.type === 'consumable';
}

// --- Item Instance (in world) ---

/**
 * An item placed in the game world.
 * References a template by ID and has a position within a specific area.
 * This is a lightweight structure - the full item data lives in the template.
 *
 * For equipped items with mutable state (ammo, quantity), instance-level
 * overrides are stored on the ItemInstance itself:
 * - currentAmmo: Current ammo count for quivers (overrides template default)
 * - quantity: Current count for stackable items like throwing weapons
 */
export const ItemInstanceSchema = z.object({
  id: z.string().min(1),
  templateId: z.string().min(1),
  x: z.number().int(),
  y: z.number().int(),
  areaId: z.string().min(1),  // Which area this item is in
  // Instance-level mutable state for equipped items
  currentAmmo: z.number().int().nonnegative().optional(),
  quantity: z.number().int().positive().optional(),
});
export type ItemInstance = z.infer<typeof ItemInstanceSchema>;

/**
 * Create a validated item instance.
 * Throws if templateId doesn't exist in ITEM_TEMPLATES.
 */
export function createItemInstance(
  id: string,
  templateId: string,
  x: number,
  y: number,
  areaId: string
): ItemInstance {
  const template = ITEM_TEMPLATES[templateId];
  if (!template) {
    throw new Error(
      `Unknown item template: '${templateId}'. ` +
      `Available templates: ${Object.keys(ITEM_TEMPLATES).join(', ')}`
    );
  }
  return ItemInstanceSchema.parse({ id, templateId, x, y, areaId });
}

// --- Item Helper Functions ---

/**
 * Get first item at position in a specific area.
 * This is the preferred function - always filters by area to prevent cross-floor bugs.
 */
export function getItemAtPosition(
  items: readonly ItemInstance[],
  x: number,
  y: number,
  areaId: string
): ItemInstance | undefined {
  return items.find(item => item.areaId === areaId && item.x === x && item.y === y);
}

/**
 * Get all items at position in a specific area.
 * This is the preferred function - always filters by area to prevent cross-floor bugs.
 */
export function getItemsAtPosition(
  items: readonly ItemInstance[],
  x: number,
  y: number,
  areaId: string
): ItemInstance[] {
  return items.filter(item => item.areaId === areaId && item.x === x && item.y === y);
}


