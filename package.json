{
  "name": "@crawlerverse/core",
  "version": "0.1.5",
  "private": false,
  "description": "AI-native roguelike game engine with multi-agent support",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/crawlerverse/core.git"
  },
  "homepage": "https://github.com/crawlerverse/core#readme",
  "bugs": "https://github.com/crawlerverse/core/issues",
  "keywords": [
    "roguelike",
    "game-engine",
    "ai-agents",
    "multi-agent",
    "typescript",
    "react"
  ],
  "author": "Crawlerverse Team",
  "scripts": {
    "postinstall": "node scripts/copy-dice-assets.js",
    "predev": "npx tsx scripts/check-ai-config.ts",
    "dev": "next dev --port 3001",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint . --ext .ts,.tsx",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "setup:ai": "npx tsx scripts/setup-ai.ts",
    "headless": "tsx bin/headless.ts"
  },
  "exports": {
    ".": "./lib/index.ts",
    "./engine": "./lib/engine/index.ts",
    "./ai": "./lib/ai/index.ts",
    "./api": "./lib/api/index.ts",
    "./headless": "./lib/headless/index.ts",
    "./components": "./components/index.ts",
    "./hooks": "./hooks/index.ts",
    "./styles/*": "./styles/*"
  },
  "files": [
    "lib",
    "components",
    "hooks",
    "app",
    "bin",
    "public",
    "scripts",
    "styles",
    "shared",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "@3d-dice/dice-box": "^1.1.4",
    "@ai-sdk/openai": "^3.0.7",
    "@ducanh2912/next-pwa": "^10.2.9",
    "@inquirer/prompts": "^8.2.0",
    "@openrouter/ai-sdk-provider": "^1.5.4",
    "ai": "^6.0.25",
    "canvas-confetti": "^1.9.4",
    "commander": "^14.0.2",
    "next": "^16.1.1",
    "pino": "^10.1.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "rot-js": "^2.2.0",
    "zod": "^3.24.1",
    "@types/canvas-confetti": "^1.9.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^5.1.2",
    "@vitest/coverage-v8": "^4.0.16",
    "@vitest/ui": "^4.0.16",
    "autoprefixer": "^10.4.23",
    "eslint": "^8.57.0",
    "eslint-config-next": "^15.1.3",
    "jsdom": "^27.4.0",
    "pino-pretty": "^13.1.3",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.21.0",
    "typescript": "^5.7.2",
    "vitest": "^4.0.16"
  }
}
